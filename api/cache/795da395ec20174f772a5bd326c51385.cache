{"expires":1773142075,"data":{"success":true,"message":"Properties retrieved successfully.","data":[{"id":16,"name":"Rafiki Lane Homes","type":"villa","status":"For Sale","beds":4,"baths":3,"size":4605,"description":"It is a luxurious 4-bedroom townhouse nestled in the quiet, leafy suburb of Lavington. This elegant residence is part of a gated community offering modern urban living with a suburban charm. The home features a spacious sunken lounge, a separate dining area, a fully fitted kitchen with granite countertops, and all bedrooms ensuite\u2014including a large master bedroom with a walk-in closet and private balcony. High ceilings and large windows ensure plenty of natural light throughout the home, while top-tier finishes add a touch of sophistication. Outside, the property boasts a private garden, a DSQ (domestic staff quarters), and two dedicated parking spots. The community enjoys 24\/7 security, a backup generator, a borehole, and beautifully landscaped common areas. Located just minutes from top international schools, shopping malls, and hospitals, Lavista Townhouse offers a perfect balance of privacy, comfort, and convenience in one of Nairobi\u2019s most prestigious neighborhoods.","agent_id":1,"facilities":["WiFi","Pool","Gym","Parking","Air Conditioning"],"hero_image":"\/uploads\/properties\/691dfbaf461c6_1763572655-thumb.jpg","gallery":["\/uploads\/properties\/691db57cc2c73.jpg"],"tour_link":"","location":"Lavington Nairobi","address":"Off James Gichuru Road","price":"53000000.00","currency":"KES","units":"{\"available\":[\"1br\",\"2br\"],\"unavailable\":[],\"linked_properties\":{\"1br\":23,\"2br\":19}}","verification_status":"pending","verification_date":null,"rating":"4.5","likes":0,"tags":[""],"floor_plan":null,"featured":0,"is_suspended":0,"sus_reason":null,"created_at":"2025-11-06 20:08:11","updated_at":"2026-03-07 14:28:12","is_deleted":0,"has_virtual_tour":0,"agent":"{\"id\":1,\"firstname\":\"Peter\",\"lastname\":\"Parker\",\"email\":\"peterp